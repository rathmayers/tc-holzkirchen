---
import { BELEGUNGEN, MEDENSPIELE_TERMINE } from '../data/platzbelegung.js';
import { getCollection } from 'astro:content';

const platzConfig = JSON.stringify({ BELEGUNGEN, MEDENSPIELE_TERMINE });

const allNews = await getCollection('news', e => e.data.published);
const latestNews = allNews.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())[0];
const newsDate = latestNews
  ? new Intl.DateTimeFormat('de-DE', { day: '2-digit', month: 'long', year: 'numeric' }).format(latestNews.data.date)
  : '';
---

<section class="relative bg-court overflow-hidden min-h-[90vh] flex items-center">

  <!-- Background – Tennis-Court-Textur mit Overlay -->
  <div class="absolute inset-0">
    <!-- Gradient statt echtem Bild als Fallback; echtes Bild als Hintergrund einsetzen -->
    <div class="absolute inset-0 bg-gradient-to-br from-court-dark via-court to-court-light opacity-90"></div>
    <!-- Subtile Court-Linien als SVG-Overlay -->
    <svg class="absolute inset-0 w-full h-full opacity-5" preserveAspectRatio="xMidYMid slice">
      <defs>
        <pattern id="court-lines" width="120" height="120" patternUnits="userSpaceOnUse">
          <path d="M 60 0 L 60 120 M 0 60 L 120 60" stroke="white" stroke-width="1" fill="none"/>
          <rect x="10" y="10" width="100" height="100" fill="none" stroke="white" stroke-width="1"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#court-lines)"/>
    </svg>
    <!-- Diagonal clay accent -->
    <div class="absolute top-0 right-0 w-[45%] h-full bg-clay/20 skew-x-[-6deg] translate-x-12 origin-top-right"></div>
  </div>

  <!-- Content -->
  <div class="relative max-w-screen-xl mx-auto px-6 py-24 md:py-32 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

    <!-- Left: Text -->
    <div class="text-white">
      <p
        class="section-label text-clay mb-4 opacity-0 animate-fade-up"
        style="animation-delay: 0.1s; animation-fill-mode: forwards"
      >
        Tennis im Herzen Bayerns
      </p>

      <h1
        class="font-display text-7xl md:text-[9rem] leading-none text-white mb-6 opacity-0 animate-fade-up"
        style="animation-delay: 0.2s; animation-fill-mode: forwards"
      >
        TC<br/>
        <span class="text-clay">Holz</span>kirchen
      </h1>

      <p
        class="text-white/70 text-lg leading-relaxed max-w-md mb-10 opacity-0 animate-fade-up"
        style="animation-delay: 0.35s; animation-fill-mode: forwards"
      >
        Willkommen in unserem Club – Sport, Gemeinschaft und Leidenschaft für Tennis
        seit über 70 Jahren. Für Einsteiger, Familien und Turnierspieler.
      </p>

      <div
        class="flex flex-wrap gap-4 opacity-0 animate-fade-up"
        style="animation-delay: 0.5s; animation-fill-mode: forwards"
      >
        <a href="/platzbuchung" class="btn-primary">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>
          </svg>
          Unsere Plätze
        </a>
        <a href="https://easyverein.com/public/TeHo/applicationform/2046" target="_blank" rel="noopener" class="btn-ghost">
          Mitglied werden →
        </a>
      </div>

      <!-- Stats bar -->
      <div
        class="flex gap-8 mt-16 pt-8 border-t border-white/10 opacity-0 animate-fade-up"
        style="animation-delay: 0.65s; animation-fill-mode: forwards"
      >
        {[
          ['6', 'Tennisplätze'],
          ['400+', 'Mitglieder'],
          ['70+', 'Jahre Tradition'],
          ['16', 'Mannschaften'],
        ].map(([num, label]) => (
          <div>
            <p class="font-display text-3xl text-clay">{num}</p>
            <p class="font-mono text-xs text-white/40 uppercase tracking-widest">{label}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Right: Floating cards -->
    <div
      class="hidden lg:flex flex-col gap-4 opacity-0 animate-slide-left"
      style="animation-delay: 0.4s; animation-fill-mode: forwards"
    >
      <!-- Neueste News Card -->
      {latestNews && (
        <div class="bg-white/10 backdrop-blur border border-white/20 p-6">
          <p class="section-label text-clay mb-3">Aktuelles</p>
          <p class="font-display text-2xl text-white leading-tight">{latestNews.data.title}</p>
          <p class="text-white/60 text-sm mt-2">{newsDate}</p>
          <a href="/news" class="btn-ghost text-xs mt-4 inline-flex">Alle News →</a>
        </div>
      )}

      <!-- Aktuelles Platzstatus Card -->
      <a href="/platzbuchung" class="bg-clay/90 backdrop-blur p-6 flex items-center justify-between group hover:bg-clay transition-colors">
        <div>
          <p class="font-mono text-xs text-white/60 uppercase tracking-widest mb-3">Platzstatus</p>
          <div class="flex items-center gap-3 mb-1">
            <div id="status-dot" class="w-3 h-3 rounded-full bg-green-400 animate-pulse shrink-0"></div>
            <p id="status-text" class="font-display text-2xl text-white">Alle Plätze ohne fixe Belegung</p>
          </div>
          <p id="status-zeit" class="text-white/70 text-sm"></p>
        </div>
        <div class="w-14 h-14 bg-white/20 flex items-center justify-center shrink-0 group-hover:bg-white/30 transition-colors ml-4">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </div>
      </a>

      <!-- Quick-Link Mannschaftsspiele -->
      <a href="/mannschaften" class="bg-white/5 backdrop-blur border border-white/10 p-6 flex items-center justify-between group hover:bg-white/10 transition-colors">
        <div>
          <p class="font-mono text-xs text-white/40 uppercase tracking-widest mb-1">Spielbetrieb</p>
          <p class="font-display text-xl text-white">Mannschaften & Spielplan</p>
        </div>
        <div class="w-10 h-10 bg-clay flex items-center justify-center shrink-0 group-hover:bg-clay-light transition-colors">
          <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </div>
      </a>
    </div>

  </div>

  <!-- Diagonal cut bottom -->
  <div class="absolute bottom-0 left-0 right-0 h-20 bg-chalk"
       style="clip-path: polygon(0 100%, 100% 0, 100% 100%)"></div>
</section>

<script define:vars={{ platzConfig }} is:inline>
const { BELEGUNGEN, MEDENSPIELE_TERMINE } = JSON.parse(platzConfig);

function zeitZuMinuten(str) {
  const [h, m] = str.split(':').map(Number);
  return h * 60 + m;
}

function irgendeinPlatzBelegt(now) {
  const dateStr = now.toISOString().split('T')[0];
  const day     = now.getDay();
  const min     = now.getHours() * 60 + now.getMinutes();

  // Feste Belegung?
  for (const b of BELEGUNGEN) {
    if (b.vonDatum && dateStr < b.vonDatum) continue;
    if (b.bisDatum && dateStr > b.bisDatum) continue;
    for (const z of b.zeiten) {
      if (!z.wochentage.includes(day)) continue;
      if (min >= zeitZuMinuten(z.von) && min < zeitZuMinuten(z.bis)) return true;
    }
  }

  // Medenspiel-Heimspieltag?
  const termin = MEDENSPIELE_TERMINE.find(t => t.datum === dateStr);
  if (termin && min >= zeitZuMinuten(termin.von)) return true;

  return false;
}

function updateStatus() {
  const now     = new Date();
  const belegt  = irgendeinPlatzBelegt(now);
  const dot     = document.getElementById('status-dot');
  const text    = document.getElementById('status-text');
  const zeitEl  = document.getElementById('status-zeit');

  if (dot)  { dot.className  = `w-3 h-3 rounded-full animate-pulse ${belegt ? 'bg-yellow-300' : 'bg-green-400'}`; }
  if (text) { text.textContent = belegt ? 'Plätze teilweise belegt' : 'Alle Plätze ohne fixe Belegung'; }
  if (zeitEl) {
    zeitEl.textContent = `Stand: ${now.toLocaleString('de-DE', { weekday:'short', day:'2-digit', month:'2-digit', hour:'2-digit', minute:'2-digit' })} Uhr`;
  }
}

updateStatus();
setInterval(updateStatus, 60_000);
</script>
