---
interface Props {
  title:        string;
  date:         Date;
  author:       string;
  category:     string;
  image?:       string;
  imageLayout?: 'klein' | 'gross';
}

const { title, date, author, category, image, imageLayout = 'klein' } = Astro.props;
const isGross = image && imageLayout === 'gross';

const formattedDate = new Intl.DateTimeFormat('de-DE', {
  day: '2-digit', month: 'long', year: 'numeric',
}).format(date);

const categoryColors: Record<string, string> = {
  'Mannschaften':  'bg-clay text-white',
  'Club':          'bg-court text-white',
  'Jugend':        'bg-emerald-600 text-white',
  'Tennisschule':  'bg-amber-600 text-white',
};
const catClass = categoryColors[category] ?? 'bg-sand-dark text-court';
---

<article class:list={[
  'news-card group flex',
  isGross ? 'flex-row' : 'flex-col',
]}>

  <!-- Bild -->
  <div class:list={[
    'bg-sand overflow-hidden relative shrink-0 flex items-center justify-center',
    isGross ? 'w-2/5' : 'h-52 w-full',
  ]}>
    {image
      ? (
        <button
          class="lightbox-trigger w-full h-full flex items-center justify-center cursor-zoom-in"
          data-src={image}
          data-alt={title}
          aria-label="Bild vergrößern"
        >
          <img
            src={image}
            alt={title}
            class="w-full h-full object-contain transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
          />
        </button>
      )
      : (
        <div class="w-full h-full bg-gradient-to-br from-court to-court-light flex items-center justify-center">
          <svg class="w-16 h-16 text-white/20" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 64 64">
            <circle cx="32" cy="32" r="28"/>
            <path d="M32 4 Q10 20 10 32 Q10 44 32 60"/>
            <path d="M32 4 Q54 20 54 32 Q54 44 32 60"/>
          </svg>
        </div>
      )
    }
    <span class:list={['absolute top-3 left-3 font-mono text-[10px] uppercase tracking-widest px-2.5 py-1', catClass]}>
      {category}
    </span>
  </div>

  <!-- Content -->
  <div class="p-6 flex flex-col flex-1 min-h-0">
    <div class="flex items-center gap-3 text-xs font-mono text-court/40 uppercase tracking-widest mb-3 shrink-0">
      <time datetime={date.toISOString()}>{formattedDate}</time>
      <span>·</span>
      <span>{author}</span>
    </div>

    <h2 class="font-display text-2xl text-court leading-tight mb-3 shrink-0">
      {title}
    </h2>

    <div class="prose prose-sm prose-court max-w-none text-court/70 leading-relaxed overflow-y-auto pr-1">
      <slot />
    </div>
  </div>
</article>
