---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { BELEGUNGEN, MEDENSPIELE } from '../../data/platzbelegung.js';
const platzConfig = JSON.stringify({ BELEGUNGEN, MEDENSPIELE });
---

<BaseLayout
  title="Unsere Plätze – TC Holzkirchen"
  description="Die Tennisanlage des TC Holzkirchen – Platz- und Spielordnung, Gästekarten und Kontakt."
>

  <div class="bg-court py-16 text-white">
    <div class="max-w-screen-xl mx-auto px-6">
      <p class="section-label text-clay mb-3">Tennisanlage</p>
      <h1 class="font-display text-7xl">Unsere<br/>Plätze</h1>
    </div>
  </div>

  <section class="py-24 bg-chalk">
    <div class="max-w-screen-xl mx-auto px-6">

      <!-- Status Platzkarten (dynamisch) -->
      <div id="platz-grid" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-4" data-animate></div>
      <p id="platz-zeit" class="font-mono text-xs text-court/30 mb-16"></p>

      <!-- Gästekarten Info -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-16" data-animate>
        <div class="bg-sand border border-sand-dark p-8">
          <p class="section-label mb-3">Für Gäste</p>
          <h2 class="font-display text-4xl text-court mb-4">Mit Gästekarte spielen</h2>
          <p class="text-court/60 leading-relaxed mb-6">
            Nicht-Mitglieder können unsere Plätze mit einer Gästekarte nutzen —
            immer zusammen mit einem Mitglied.
          </p>
          <div class="flex gap-8 mb-6">
            <div>
              <p class="font-display text-3xl text-clay">7,50 €</p>
              <p class="font-mono text-xs text-court/40 uppercase tracking-widest">Erwachsene</p>
            </div>
            <div>
              <p class="font-display text-3xl text-clay">5,00 €</p>
              <p class="font-mono text-xs text-court/40 uppercase tracking-widest">Jugendliche</p>
            </div>
          </div>
          <div class="border-t border-sand-dark pt-4 space-y-1 text-sm text-court/60">
            <p class="font-mono text-xs text-court/40 uppercase tracking-widest mb-2">Gästekarten erhältlich bei</p>
            <p>Gesundheitszentrum Holzer, Tölzer Str. 13 <span class="text-court/40">(Mo–Do 8–20 Uhr, Fr 8–16 Uhr)</span></p>
            <p>Dr. Claudia Benkert, Krankenhausstr. 34a</p>
            <p>Dr. Antje Krepek, Flinspachstr. 1</p>
            <p>Gerhard Westner, Kiem Pauli Str. 23</p>
          </div>
        </div>

        <div class="bg-white border border-sand-dark p-8">
          <p class="section-label mb-3">Platz- & Spielordnung</p>
          <h2 class="font-display text-4xl text-court mb-6">So funktioniert's</h2>
          <ul class="space-y-4 text-sm text-court/60 leading-relaxed">
            <li class="flex gap-3">
              <span class="font-display text-clay text-lg leading-none mt-0.5">1</span>
              <span>Mitgliedskarte oder ausgefüllte Gästekarte an der Platztafel einhängen — damit ist der Platz reserviert.</span>
            </li>
            <li class="flex gap-3">
              <span class="font-display text-clay text-lg leading-none mt-0.5">2</span>
              <span>Spielzeit: <strong class="text-court">1 Stunde</strong> (Einzel) · <strong class="text-court">1,5 Stunden</strong> (Doppel/Mixed). Uhr auf Spielbeginn stellen.</span>
            </li>
            <li class="flex gap-3">
              <span class="font-display text-clay text-lg leading-none mt-0.5">3</span>
              <span>Sind alle Plätze belegt, in der 2. Reihe vormerken — Anwesenheit während der Wartezeit nicht erforderlich.</span>
            </li>
            <li class="flex gap-3">
              <span class="font-display text-clay text-lg leading-none mt-0.5">4</span>
              <span>Kinder bis 14 Jahre dürfen auf allen Plätzen bis 17 Uhr und auf Platz 6 zeitlich unbegrenzt spielen.</span>
            </li>
            <li class="flex gap-3">
              <span class="font-display text-clay text-lg leading-none mt-0.5">5</span>
              <span>Plätze nach dem Spiel abziehen. Nur Tennisschuhe erlaubt. Bei Platzsperrung das Schild „Plätze nicht bespielbar" beachten.</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Kontakt -->
      <div class="border-t border-sand-dark pt-16" data-animate>
        <p class="section-label mb-4">Kontakt & Fragen</p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="tel:+498024123456" class="btn-primary">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.15 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.05 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21 17l.92-.08z"/>
            </svg>
            +49 8024 123 456
          </a>
          <a href="mailto:info@tc-holzkirchen.de" class="btn-outline">
            info@tc-holzkirchen.de
          </a>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>

<script define:vars={{ platzConfig }}>
const { BELEGUNGEN, MEDENSPIELE } = JSON.parse(platzConfig);

function zeitZuMinuten(str) {
  const [h, m] = str.split(':').map(Number);
  return h * 60 + m;
}

function getPlatzStatus(platzNr, now) {
  const dateStr = now.toISOString().split('T')[0];
  const day     = now.getDay();
  const min     = now.getHours() * 60 + now.getMinutes();

  // 1. Rot: feste Belegung
  for (const b of BELEGUNGEN) {
    if (!b.plaetze.includes(platzNr)) continue;
    if (b.vonDatum && dateStr < b.vonDatum) continue;
    if (b.bisDatum && dateStr > b.bisDatum) continue;
    for (const z of b.zeiten) {
      if (!z.wochentage.includes(day)) continue;
      if (min >= zeitZuMinuten(z.von) && min < zeitZuMinuten(z.bis)) {
        return { farbe: 'rot', text: 'Belegt durch Training, Mannschaft oder Verein' };
      }
    }
  }

  // 2. Orange: Medenspiele (Fr 15:00 – So 20:00 innerhalb der Saison)
  if (dateStr >= MEDENSPIELE.vonDatum && dateStr <= MEDENSPIELE.bisDatum) {
    const frAb  = zeitZuMinuten(MEDENSPIELE.freitag_ab);
    const soBis = zeitZuMinuten(MEDENSPIELE.sonntag_bis);
    if (
      (day === 5 && min >= frAb) ||
       day === 6 ||
      (day === 0 && min <= soBis)
    ) {
      return { farbe: 'orange', text: 'Platzbelegung durch Medenspiele entsprechend Aushang am Platz' };
    }
  }

  // 3. Grün: frei
  return { farbe: 'gruen', text: 'Platz nach Verfügbarkeit vor Ort spielbar' };
}

const FARBEN = {
  gruen:  { bg: 'bg-emerald-50',  border: 'border-emerald-400', text: 'text-emerald-800', dot: 'bg-emerald-400' },
  orange: { bg: 'bg-amber-50',    border: 'border-amber-400',   text: 'text-amber-800',   dot: 'bg-amber-400'   },
  rot:    { bg: 'bg-red-50',      border: 'border-red-400',     text: 'text-red-800',     dot: 'bg-red-400'     },
};

function render() {
  const now  = new Date();
  const grid = document.getElementById('platz-grid');
  const zeit = document.getElementById('platz-zeit');
  if (!grid) return;

  grid.innerHTML = [1,2,3,4,5,6].map(nr => {
    const { farbe, text } = getPlatzStatus(nr, now);
    const f = FARBEN[farbe];
    return `
      <div class="border ${f.bg} ${f.border} ${f.text} p-5 flex flex-col gap-2">
        <div class="flex items-center gap-2">
          <span class="w-2 h-2 rounded-full ${f.dot} shrink-0"></span>
          <p class="font-display text-2xl leading-none">Platz ${nr}</p>
        </div>
        <p class="font-mono text-[10px] uppercase tracking-widest leading-tight">${text}</p>
      </div>`;
  }).join('');

  if (zeit) {
    zeit.textContent = `Stand: ${now.toLocaleString('de-DE', { weekday:'long', day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit' })} Uhr`;
  }
}

render();
// Jede Minute neu prüfen
setInterval(render, 60_000);
</script>
