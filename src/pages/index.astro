---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import NewsCard from '../components/NewsCard.astro';
import { getCollection } from 'astro:content';

const allNews = await getCollection('news', e => e.data.published);
const sortedNews = allNews.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const latestNews = sortedNews.slice(0, 4);
---

<BaseLayout>

  <!-- ░░ HERO ░░ -->
  <Hero />

  <!-- ░░ ÜBER UNS TEASER ░░ -->
  <section class="py-24 bg-chalk">
    <div class="max-w-screen-xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <div data-animate>
        <p class="section-label mb-3">Unser Club</p>
        <h2 class="section-title mb-6">Tennis.<br/>Gemeinschaft.<br/>Heimat.</h2>
        <p class="text-court/60 leading-relaxed max-w-prose mb-4">
          Der TC Holzkirchen ist mehr als ein Sportverein – wir sind eine lebendige Gemeinschaft
          von über 400 Mitgliedern aus der Region. Ob Kinder beim ersten Aufschlag oder erfahrene
          Spieler in der Bezirksliga – hier ist jeder willkommen.
        </p>
        <p class="text-court/60 leading-relaxed max-w-prose mb-8">
          Unsere 12 Plätze – davon 4 mit Flutlicht – bieten optimale Bedingungen das ganze Jahr.
        </p>
        <a href="/club" class="btn-outline">Mehr über uns</a>
      </div>

      <!-- Feature-Kacheln -->
      <div class="grid grid-cols-2 gap-4" data-animate>
        {[
          { icon: '🎾', title: '12 Plätze', desc: 'Sand & Hartplätze, 4× Flutlicht' },
          { icon: '👨‍👩‍👧', title: 'Familien', desc: 'Kursangebote für alle Altersgruppen' },
          { icon: '🏆', title: 'Mannschaft', desc: '8 Teams im aktiven Spielbetrieb' },
          { icon: '📅', title: 'Buchung', desc: 'Online reservieren, jederzeit' },
        ].map(item => (
          <div class="bg-sand p-6 border border-sand-dark hover:border-clay transition-colors">
            <span class="text-3xl mb-3 block">{item.icon}</span>
            <h3 class="font-display text-xl text-court mb-1">{item.title}</h3>
            <p class="text-sm text-court/50">{item.desc}</p>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ░░ PLATZ BUCHEN BANNER ░░ -->
  <section class="bg-clay diagonal-divider py-20 -mb-8">
    <div class="max-w-screen-xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-8">
      <div>
        <p class="section-label text-white/60 mb-2">Schnell & einfach</p>
        <h2 class="font-display text-5xl text-white">Platz online buchen</h2>
        <p class="text-white/70 mt-2 text-sm">Verfügbarkeit prüfen und sofort reservieren.</p>
      </div>
      <a
        href="/platzbuchung"
        class="inline-flex items-center gap-3 bg-white text-clay font-body font-medium px-8 py-4 uppercase tracking-widest text-sm hover:bg-sand transition-colors shrink-0"
      >
        Zur Platzbuchung
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- ░░ NEWS ░░ -->
  <section class="py-28 bg-chalk">
    <div class="max-w-screen-xl mx-auto px-6">

      <div class="flex items-end justify-between mb-12" data-animate>
        <div>
          <p class="section-label mb-3">Aktuelles</p>
          <h2 class="section-title">News &<br/>Berichte</h2>
        </div>
        <a href="/news" class="btn-outline hidden sm:inline-flex">Alle News</a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-6" data-animate>
        {latestNews.map(entry => (
          <NewsCard
            title={entry.data.title}
            summary={entry.data.summary}
            date={entry.data.date}
            author={entry.data.author}
            category={entry.data.category}
            slug={entry.slug}
            image={entry.data.image}
            featured={entry.data.featured}
          />
        ))}
      </div>

      <div class="text-center mt-10 sm:hidden">
        <a href="/news" class="btn-outline">Alle News ansehen</a>
      </div>
    </div>
  </section>

  <!-- ░░ MITGLIED WERDEN ░░ -->
  <section class="bg-court py-24 diagonal-divider-reverse">
    <div class="max-w-screen-xl mx-auto px-6 text-center" data-animate>
      <p class="section-label text-clay mb-4">Jetzt dabei sein</p>
      <h2 class="font-display text-6xl md:text-8xl text-white mb-6">Werde Mitglied</h2>
      <p class="text-white/60 max-w-lg mx-auto mb-10 leading-relaxed">
        Starte deine Tennisreise beim TC Holzkirchen. Flexible Mitgliedschaftsmodelle
        für Einzelpersonen, Familien und Jugendliche.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/mitglied-werden" class="btn-primary">Mitglied werden</a>
        <a href="/club" class="inline-flex items-center gap-2 text-white/70 hover:text-white font-mono text-xs uppercase tracking-widest border-b border-white/20 hover:border-white transition-all pb-1">
          Mehr erfahren
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
