---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allNews  = await getCollection('news');
const rawFiles = import.meta.glob('/src/content/news/*.mdx', { as: 'raw' });

const newsData = await Promise.all(allNews.map(async entry => {
  const filePath = `/src/content/news/${entry.id}`;
  const raw = rawFiles[filePath] ? await rawFiles[filePath]() : '';
  const parts = raw.split(/^---\s*$/m);
  const body  = parts.length >= 3 ? parts.slice(2).join('---').trim() : '';
  return {
    slug: entry.slug, title: entry.data.title, summary: entry.data.summary ?? '',
    date: entry.data.date.toISOString().split('T')[0], author: entry.data.author,
    category: entry.data.category, image: entry.data.image ?? '',
    imageLayout: entry.data.imageLayout ?? 'klein', featured: entry.data.featured ?? false,
    published: entry.data.published ?? true, id: entry.id, body,
  };
}));
const newsJSON = JSON.stringify(newsData);
---

<BaseLayout title="News – Admin TC Holzkirchen">
  <div class="bg-court/5 border-b border-sand-dark py-6">
    <div class="max-w-screen-xl mx-auto px-6 flex items-center justify-between">
      <div class="flex items-center gap-4">
        <a href="/admin" class="font-mono text-xs text-court/40 uppercase tracking-widest hover:text-clay transition-colors">← Logout</a>
        <span class="text-sand-dark">/</span>
        <a href="/admin/news-liste" class="font-mono text-xs text-court/40 uppercase tracking-widest hover:text-clay transition-colors">Alle News</a>
        <span class="text-sand-dark">/</span>
        <h1 id="page-title" class="font-display text-2xl text-court">Neuer Beitrag</h1>
      </div>
      <a href="/news" class="btn-outline text-xs py-2.5 px-4">Website ansehen</a>
    </div>
  </div>

  <div class="max-w-screen-xl mx-auto px-6 py-12 grid grid-cols-1 lg:grid-cols-3 gap-10">

    <!-- Form -->
    <div class="lg:col-span-2">
      <div class="bg-white border border-sand-dark p-8">
        <h2 class="font-display text-3xl text-court mb-8">Neuen Beitrag erstellen</h2>

        <div id="admin-form" class="space-y-6">

          <!-- Titel -->
          <div>
            <label class="form-label" for="news-title">Titel *</label>
            <input
              type="text"
              id="news-title"
              class="form-input"
              placeholder="z.B. Saisonstart 2025"
              required
            />
          </div>

          <!-- Zusammenfassung -->
          <div>
            <label class="form-label" for="news-summary">Kurzbeschreibung * <span class="text-court/30">(für Karten-Vorschau)</span></label>
            <textarea
              id="news-summary"
              rows="2"
              class="form-input resize-none"
              placeholder="Kurze Zusammenfassung des Beitrags..."
              required
            ></textarea>
          </div>

          <!-- Kategorie + Datum -->
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="form-label" for="news-category">Kategorie *</label>
              <select id="news-category" class="form-input">
                <option value="Mannschaften">Mannschaften</option>
                <option value="Club">Club</option>
                <option value="Jugend">Jugend</option>
                <option value="Tennisschule">Tennisschule</option>
              </select>
            </div>
            <div>
              <label class="form-label" for="news-date">Datum *</label>
              <input type="date" id="news-date" class="form-input" required />
            </div>
          </div>

          <!-- Autor -->
          <div>
            <label class="form-label" for="news-author">Autor *</label>
            <input type="text" id="news-author" class="form-input" placeholder="z.B. Vorstand TC Holzkirchen" />
          </div>

          <!-- Inhalt (Markdown) -->
          <div>
            <label class="form-label" for="news-content">
              Inhalt (Markdown) *
              <span class="text-court/30 ml-2 lowercase">**fett**, *kursiv*, ## Überschrift, - Liste</span>
            </label>
            <textarea
              id="news-content"
              rows="12"
              class="form-input resize-y font-mono text-sm leading-relaxed"
              placeholder="# Überschrift&#10;&#10;Hier beginnt der Beitrag...&#10;&#10;## Abschnitt&#10;&#10;Text mit **Fettschrift** und *Kursivschrift*."
            ></textarea>
          </div>

          <!-- Bild URL -->
          <div>
            <label class="form-label" for="news-image">Bild-URL <span class="text-court/30">(optional, /images/news/bild.jpg)</span></label>
            <input type="text" id="news-image" class="form-input" placeholder="/images/news/mein-bild.jpg" />
          </div>

          <!-- Bildlayout -->
          <div>
            <label class="form-label">Bildlayout</label>
            <div class="flex gap-6 mt-1">
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="image-layout" id="layout-klein" value="klein" class="accent-clay" checked />
                <span class="text-sm text-court/70">Klein <span class="text-court/40">(Bild oben, Text darunter)</span></span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="image-layout" id="layout-gross" value="gross" class="accent-clay" />
                <span class="text-sm text-court/70">Groß <span class="text-court/40">(Bild links, Text rechts)</span></span>
              </label>
            </div>
          </div>

          <!-- Featured -->
          <div class="flex items-center gap-3">
            <input type="checkbox" id="news-featured" class="w-4 h-4 accent-clay" />
            <label for="news-featured" class="font-mono text-xs uppercase tracking-widest text-court/60">
              Als Featured-Beitrag markieren
            </label>
          </div>

          <!-- Actions -->
          <div class="flex items-center gap-4 pt-4 border-t border-sand-dark">
            <button id="publish-btn" class="btn-primary">
              Veröffentlichen
            </button>
            <span id="publish-status" class="font-mono text-sm hidden"></span>
          </div>
        </div>
      </div>
    </div>
      </div>
    </div>

    <!-- Sidebar: Tipps -->
    <aside class="space-y-6">
      <div class="bg-white border border-sand-dark p-6">
        <h3 class="font-display text-xl text-court mb-4">Schnellhilfe</h3>
        <ul class="space-y-3 text-sm text-court/60 font-mono">
          <li><code class="bg-sand px-1.5 py-0.5 text-court text-xs">**Text**</code> → <strong>fett</strong></li>
          <li><code class="bg-sand px-1.5 py-0.5 text-court text-xs">*Text*</code> → <em>kursiv</em></li>
          <li><code class="bg-sand px-1.5 py-0.5 text-court text-xs">## Titel</code> → Überschrift</li>
          <li><code class="bg-sand px-1.5 py-0.5 text-court text-xs">- Punkt</code> → Liste</li>
          <li><code class="bg-sand px-1.5 py-0.5 text-court text-xs">[Link](URL)</code> → Verlinkung</li>
        </ul>
      </div>

      <div class="bg-court text-white p-6">
        <h3 class="font-display text-xl mb-3">Workflow</h3>
        <ol class="space-y-3 text-sm text-white/60">
          <li class="flex gap-3"><span class="font-display text-clay text-lg leading-none">1</span><span>Formular ausfüllen</span></li>
          <li class="flex gap-3"><span class="font-display text-clay text-lg leading-none">2</span><span>„Veröffentlichen" klicken</span></li>
          <li class="flex gap-3"><span class="font-display text-clay text-lg leading-none">3</span><span>Fertig — Seite aktualisiert sich automatisch</span></li>
        </ol>
      </div>

      <div class="bg-sand border border-sand-dark p-6 text-sm text-court/60">
        <p class="font-mono text-xs text-clay uppercase tracking-widest mb-2">Geplant: CMS-Integration</p>
        <p>In einem nächsten Schritt kann ein Headless-CMS (z.B. Decap CMS, Keystatic oder Directus) angebunden werden, damit Redakteure Beiträge direkt über ein visuelles Interface verwalten können.</p>
      </div>
    </aside>

  </div>
</BaseLayout>

<script define:vars={{ newsJSON }} is:inline>
  if (!sessionStorage.getItem('tc-admin')) window.location.href = '/admin';

  var ALL_NEWS  = JSON.parse(newsJSON);
  var editSlug  = new URLSearchParams(location.search).get('edit');
  var editEntry = editSlug ? ALL_NEWS.find(function(n) { return n.slug === editSlug; }) : null;

  if (editEntry) {
    document.getElementById('page-title').textContent   = 'Beitrag bearbeiten';
    document.getElementById('publish-btn').textContent  = 'Änderungen speichern';
  }

  document.getElementById('news-date').value = editEntry
    ? editEntry.date : new Date().toISOString().split('T')[0];

  if (editEntry) {
    document.getElementById('news-title').value    = editEntry.title;
    document.getElementById('news-summary').value  = editEntry.summary;
    document.getElementById('news-author').value   = editEntry.author;
    document.getElementById('news-content').value  = editEntry.body;
    document.getElementById('news-image').value    = editEntry.image;
    document.getElementById('news-category').value = editEntry.category;
    document.getElementById('news-featured').checked = editEntry.featured;
    var lr = document.querySelector('input[name="image-layout"][value="' + editEntry.imageLayout + '"]');
    if (lr) lr.checked = true;
  }

  function slugify(text) {
    return text.toLowerCase()
      .replace(/ä/g,'ae').replace(/ö/g,'oe').replace(/ü/g,'ue').replace(/ß/g,'ss')
      .replace(/[^a-z0-9\s-]/g,'').trim()
      .replace(/\s+/g,'-').replace(/-+/g,'-');
  }

  function buildMDX() {
    var title       = document.getElementById('news-title').value.trim();
    var summary     = document.getElementById('news-summary').value.trim();
    var category    = document.getElementById('news-category').value;
    var date        = document.getElementById('news-date').value;
    var author      = document.getElementById('news-author').value.trim();
    var content     = document.getElementById('news-content').value.trim();
    var image       = document.getElementById('news-image').value.trim();
    var featured    = document.getElementById('news-featured').checked;
    var layoutEl    = document.querySelector('input[name="image-layout"]:checked');
    var imageLayout = layoutEl ? layoutEl.value : 'klein';
    var imageLine       = image ? '\nimage: "' + image + '"' : '';
    var imageLayoutLine = (image && imageLayout === 'gross') ? '\nimageLayout: "gross"' : '';
    var featuredLine    = featured ? '\nfeatured: true' : '';
    return '---\ntitle: "' + title + '"\nsummary: "' + summary + '"\ndate: ' + date +
      '\nauthor: "' + author + '"\ncategory: "' + category + '"' +
      imageLine + imageLayoutLine + featuredLine + '\npublished: true\n---\n\n' + content;
  }

  function setStatus(msg, ok) {
    var el = document.getElementById('publish-status');
    el.textContent  = msg;
    el.className    = 'font-mono text-sm ' + (ok ? 'text-emerald-600' : 'text-clay');
    el.classList.remove('hidden');
  }

  document.getElementById('publish-btn').addEventListener('click', function() {
    var title = document.getElementById('news-title').value.trim();
    if (!title) { alert('Bitte einen Titel eingeben.'); return; }

    var dateVal  = document.getElementById('news-date').value;
    var filename = editEntry ? editEntry.id : dateVal + '-' + slugify(title) + '.mdx';
    var content  = buildMDX();
    var btn      = document.getElementById('publish-btn');

    btn.disabled    = true;
    btn.textContent = 'Wird veröffentlicht…';
    setStatus('', true);

    fetch('/api/save-news', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ filename: filename, content: content }),
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.success) {
        setStatus('✓ Erfolgreich veröffentlicht! Die Seite wird in ~1 Minute aktualisiert.', true);
        btn.textContent = editEntry ? 'Änderungen speichern' : 'Veröffentlichen';
        btn.disabled    = false;
        if (!editEntry) setTimeout(function() { window.location.href = '/admin/news-liste'; }, 2000);
      } else {
        setStatus('Fehler: ' + (data.error || 'Unbekannter Fehler'), false);
        btn.textContent = editEntry ? 'Änderungen speichern' : 'Veröffentlichen';
        btn.disabled    = false;
      }
    })
    .catch(function(err) {
      setStatus('Verbindungsfehler: ' + err.message, false);
      btn.textContent = editEntry ? 'Änderungen speichern' : 'Veröffentlichen';
      btn.disabled    = false;
    });
  });
</script>
