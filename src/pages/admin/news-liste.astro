---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allNews = await getCollection('news');
const sorted  = allNews.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Rohinhalte aller MDX-Dateien für den Edit-Modus
const rawFiles = import.meta.glob('/src/content/news/*.mdx', { as: 'raw' });

// Daten für Client serialisieren
const newsData = await Promise.all(sorted.map(async entry => {
  const filePath = `/src/content/news/${entry.id}`;
  const raw = rawFiles[filePath] ? await rawFiles[filePath]() : '';
  // Body = alles nach dem zweiten ---
  const parts = raw.split(/^---\s*$/m);
  const body  = parts.length >= 3 ? parts.slice(2).join('---').trim() : '';
  return {
    id:          entry.id,
    slug:        entry.slug,
    title:       entry.data.title,
    summary:     entry.data.summary ?? '',
    date:        entry.data.date.toISOString().split('T')[0],
    author:      entry.data.author,
    category:    entry.data.category,
    image:       entry.data.image ?? '',
    imageLayout: entry.data.imageLayout ?? 'klein',
    featured:    entry.data.featured ?? false,
    published:   entry.data.published ?? true,
    body,
  };
}));

const newsJSON = JSON.stringify(newsData);
---

<BaseLayout title="News-Liste – Admin TC Holzkirchen">

  <!-- Header -->
  <div class="bg-court/5 border-b border-sand-dark py-6">
    <div class="max-w-screen-xl mx-auto px-6 flex items-center justify-between">
      <div class="flex items-center gap-4">
        <a href="/admin/news-erstellen" class="font-mono text-xs text-court/40 uppercase tracking-widest hover:text-clay transition-colors">← Neuer Beitrag</a>
        <span class="text-sand-dark">/</span>
        <h1 class="font-display text-2xl text-court">Alle News</h1>
      </div>
      <a href="/news" class="btn-outline text-xs py-2.5 px-4">Website ansehen</a>
    </div>
  </div>

  <div class="max-w-screen-xl mx-auto px-6 py-12">

    <!-- Suche -->
    <div class="mb-6">
      <input id="search" type="text" placeholder="Beitrag suchen..." class="form-input max-w-sm" />
    </div>

    <!-- Tabelle -->
    <div class="bg-white border border-sand-dark overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-sand border-b border-sand-dark">
          <tr>
            <th class="text-left px-5 py-3 font-mono text-xs text-court/50 uppercase tracking-widest">Titel</th>
            <th class="text-left px-5 py-3 font-mono text-xs text-court/50 uppercase tracking-widest hidden md:table-cell">Datum</th>
            <th class="text-left px-5 py-3 font-mono text-xs text-court/50 uppercase tracking-widest hidden lg:table-cell">Kategorie</th>
            <th class="text-left px-5 py-3 font-mono text-xs text-court/50 uppercase tracking-widest hidden lg:table-cell">Status</th>
            <th class="px-5 py-3"></th>
          </tr>
        </thead>
        <tbody id="news-table" class="divide-y divide-sand-dark">
          <!-- wird per JS gefüllt -->
        </tbody>
      </table>
      <p id="empty-msg" class="hidden text-center py-16 text-court/30 font-mono text-sm">Keine Beiträge gefunden.</p>
    </div>

  </div>

  <!-- Lösch-Dialog -->
  <div id="delete-dialog" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 p-4">
    <div class="bg-white border border-sand-dark p-8 max-w-lg w-full">
      <h2 class="font-display text-2xl text-court mb-2">Beitrag löschen</h2>
      <p class="text-court/60 text-sm mb-4">Diesen Beitrag wirklich unwiderruflich löschen?</p>
      <p class="font-mono text-sm text-clay mb-6" id="delete-filename"></p>
      <div id="delete-status" class="hidden mb-4 font-mono text-sm"></div>
      <div class="flex gap-3">
        <button id="delete-confirm" class="btn-primary text-sm bg-red-600 border-red-600 hover:bg-red-700">Endgültig löschen</button>
        <button id="delete-close" class="btn-outline text-sm">Abbrechen</button>
      </div>
    </div>
  </div>

</BaseLayout>

<script define:vars={{ newsJSON }} is:inline>
if (!sessionStorage.getItem('tc-admin')) window.location.href = '/admin';

var NEWS = JSON.parse(newsJSON);

function renderTable(items) {
  const tbody   = document.getElementById('news-table');
  const emptyMsg = document.getElementById('empty-msg');
  if (!items.length) { tbody.innerHTML = ''; emptyMsg.classList.remove('hidden'); return; }
  emptyMsg.classList.add('hidden');

  tbody.innerHTML = items.map(n => `
    <tr class="hover:bg-sand/40 transition-colors" data-slug="${n.slug}">
      <td class="px-5 py-4">
        <p class="font-medium text-court">${n.title}</p>
        <p class="text-xs text-court/40 font-mono mt-0.5">${n.id}</p>
      </td>
      <td class="px-5 py-4 text-court/60 hidden md:table-cell">${n.date}</td>
      <td class="px-5 py-4 hidden lg:table-cell">
        <span class="font-mono text-[10px] uppercase tracking-widest px-2 py-1 bg-sand text-court/60">${n.category}</span>
      </td>
      <td class="px-5 py-4 hidden lg:table-cell">
        <span class="font-mono text-[10px] uppercase tracking-widest ${n.published ? 'text-emerald-600' : 'text-court/30'}">
          ${n.published ? '● Veröffentlicht' : '○ Entwurf'}
        </span>
      </td>
      <td class="px-5 py-4">
        <div class="flex gap-2 justify-end">
          <a href="/admin/news-erstellen?edit=${encodeURIComponent(n.slug)}"
             class="font-mono text-xs text-clay uppercase tracking-widest hover:underline">
            Bearbeiten
          </a>
          <span class="text-court/20">|</span>
          <button class="delete-btn font-mono text-xs text-court/40 uppercase tracking-widest hover:text-clay transition-colors"
                  data-id="${n.id}">
            Löschen
          </button>
        </div>
      </td>
    </tr>
  `).join('');

  // Lösch-Buttons
  tbody.querySelectorAll('.delete-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      currentDeleteId = btn.dataset.id;
      document.getElementById('delete-filename').textContent = currentDeleteId;
      var dialog = document.getElementById('delete-dialog');
      dialog.classList.remove('hidden');
      dialog.classList.add('flex');
    });
  });
}

// Suche
document.getElementById('search').addEventListener('input', e => {
  const q = e.target.value.toLowerCase();
  renderTable(q ? NEWS.filter(n => n.title.toLowerCase().includes(q) || n.category.toLowerCase().includes(q)) : NEWS);
});

// Lösch-Dialog
var currentDeleteId = null;

function closeDeleteDialog() {
  var d = document.getElementById('delete-dialog');
  d.classList.add('hidden'); d.classList.remove('flex');
  document.getElementById('delete-status').classList.add('hidden');
  currentDeleteId = null;
}

document.getElementById('delete-close').addEventListener('click', closeDeleteDialog);

document.getElementById('delete-confirm').addEventListener('click', function() {
  if (!currentDeleteId) return;
  var btn = document.getElementById('delete-confirm');
  btn.disabled = true; btn.textContent = 'Wird gelöscht…';
  var statusEl = document.getElementById('delete-status');

  fetch('/api/delete-news', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ filename: currentDeleteId }),
  })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    if (data.success) {
      statusEl.textContent = '✓ Gelöscht! Seite aktualisiert sich in ~1 Minute.';
      statusEl.className = 'font-mono text-sm text-emerald-600 mb-4';
      statusEl.classList.remove('hidden');
      // Zeile aus Tabelle entfernen
      var row = document.querySelector('tr[data-slug]');
      NEWS = NEWS.filter(function(n) { return n.id !== currentDeleteId; });
      renderTable(NEWS);
      setTimeout(closeDeleteDialog, 2000);
    } else {
      statusEl.textContent = 'Fehler: ' + (data.error || 'Unbekannt');
      statusEl.className = 'font-mono text-sm text-clay mb-4';
      statusEl.classList.remove('hidden');
      btn.disabled = false; btn.textContent = 'Endgültig löschen';
    }
  })
  .catch(function(err) {
    statusEl.textContent = 'Verbindungsfehler: ' + err.message;
    statusEl.className = 'font-mono text-sm text-clay mb-4';
    statusEl.classList.remove('hidden');
    btn.disabled = false; btn.textContent = 'Endgültig löschen';
  });
});

renderTable(NEWS);
</script>
